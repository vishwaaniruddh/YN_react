# Apache React SPA Routing + Old WordPress URL Removal .htaccess
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # -----------------------------------------------
  # STEP 0: EXCLUDE ADMIN DIRECTORY & API
  # Admin panel is internal - NEVER apply 410s or SPA rewrites to /admin
  # -----------------------------------------------
  RewriteCond %{REQUEST_URI} ^/admin [NC]
  RewriteRule ^ - [L]

  # -----------------------------------------------
  # STEP 1: Kill old WordPress-style hash/dBsaN URLs
  # These are OLD indexed WordPress pages - return 410 GONE
  # so Google removes them FAST (faster than 404)
  # -----------------------------------------------
  RewriteCond %{REQUEST_URI} ^/dBsaN [NC]
  RewriteRule ^ - [R=410,L]

  RewriteCond %{REQUEST_URI} ^/wp- [NC]
  RewriteRule ^ - [R=410,L]

  RewriteCond %{REQUEST_URI} ^/wordpress [NC]
  RewriteRule ^ - [R=410,L]

  # Kill old WordPress ?p=123, ?page_id=123 query params
  RewriteCond %{REQUEST_URI} !^/admin [NC]
  RewriteCond %{QUERY_STRING} ^(p|page_id|cat|tag|author)=\d+ [NC]
  RewriteRule ^ - [R=410,L]

  # Kill Japanese SEO spam hack single-letter query strings (e.g. /?y=518027474, /?m=65204580838)
  RewriteCond %{REQUEST_URI} !^/admin [NC]
  RewriteCond %{QUERY_STRING} ^[a-z]=\d+$ [NC]
  RewriteRule ^$ - [R=410,L]

  # -----------------------------------------------
  # STEP 2: Normal React SPA routing (for new site)
  # -----------------------------------------------
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# 410 GONE error document for humans while keeping 410 status for search crawlers
ErrorDocument 410 "<!DOCTYPE html><html><head><meta charset='utf-8'><title>410 Page Gone - YosshitaNeha</title><style>body{font-family:sans-serif;background:#0f172a;color:#fff;text-align:center;padding:80px 20px;}a{display:inline-block;margin-top:20px;padding:12px 24px;background:#c8a55c;color:#000;text-decoration:none;font-weight:bold;border-radius:6px;}</style></head><body><h2>This Link Is No Longer Available</h2><p>The page you requested has been permanently removed.</p><a href='/'>Return to YosshitaNeha Studio</a></body></html>"
